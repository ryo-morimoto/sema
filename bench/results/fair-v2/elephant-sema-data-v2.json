      ],
      "names": [
        "fetchAnalyticssFromAPI",
        "fetchInventorysFromAPI",
        "fetchOrdersFromAPI",
        "fetchUsersFromAPI"
      ]
    },
    {
      "purity": "pure",
      "names": [
        "formatAnalyticsSummary",
        "formatInventorySummary",
        "formatOrderSummary",
        "formatUserSummary"
      ]
    },
    {
      "purity": "effectful",
      "capabilities": [
        "io:console"
      ],
      "names": [
        "logAnalyticsEvent",
        "logInventoryEvent",
        "logOrderEvent",
